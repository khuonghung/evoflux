@startuml system-architecture
!theme plain
skin backgroundColor #0a0a0a
skin defaultFontColor #ededed
skin defaultFontSize 13
skin componentStyle rectangle
skin packageStyle rectangle

skinparam package {
  BackgroundColor #111111
  BorderColor #333333
  FontColor #ededed
  RoundCorner 12
}

skinparam component {
  BackgroundColor #171717
  BorderColor #333333
  FontColor #ededed
  RoundCorner 8
}

skinparam database {
  BackgroundColor #171717
  BorderColor #333333
  FontColor #ededed
}

skinparam arrow {
  Color #0070f3
  FontColor #888888
}

title **Evoflux — System Architecture**\n

package "Electron Main Process" as main #0f172a {
  [IPC Handlers] as ipc
  [Graph Engine] as engine
  [Sandbox Manager] as sandbox
  database "SQLite\n~/.evoflux/evoflux.db" as db
}

package "Preload (contextBridge)" as preload #1c1917 {
  [window.api\n{workflow, ai, sandbox,\nmemory, settings}] as bridge
}

package "Renderer Process (React + Vite)" as renderer #1e1028 {
  package "Canvas" as canvas {
    [ReactFlow\nNodes + Edges] as rf
    [Node Popup\nSettings Editor] as popup
    [Run Panel\nExecution Monitor] as run
  }
  
  package "AI System" as ai {
    [AI Assistant\nReAct Engine] as assistant
    [10 Workflow Tools] as tools
    [Provider Manager] as providers
  }
  
  package "State (Zustand)" as stores {
    [workflowStore] as ws
    [providerStore] as ps
    [settingsStore] as ss
    [assistantStore] as as
  }
  
  package "UI" as ui {
    [Dashboard] as dash
    [Settings Page] as settings
    [Floating Dock] as dock
  }
}

' Connections
ipc --> db : read/write
engine --> db : runs + memory
ipc <--> bridge : IPC invoke/send
bridge <--> stores : sync
stores <--> canvas : state
assistant --> tools : execute
tools --> stores : modify canvas
providers --> ipc : AI requests
ui --> stores : user actions

note right of db
  11 tables:
  settings, providers, workflows,
  runs, node_runs,
  memory_semantic/episodic/procedural,
  memory_edges, env_variables,
  schema_version
end note

@enduml
