@startuml workflow-execution
!theme plain
skin backgroundColor #0a0a0a
skin defaultFontColor #ededed
skin defaultFontSize 12
skinparam sequenceArrowColor #0070f3
skinparam sequenceLifeLineBorderColor #333333
skinparam sequenceParticipantBackgroundColor #171717
skinparam sequenceParticipantBorderColor #333333
skinparam sequenceParticipantFontColor #ededed
skinparam sequenceGroupBackgroundColor #111111
skinparam sequenceGroupBorderColor #333333

title **Evoflux — Workflow Execution Sequence**\n

participant "User" as user
participant "RunDialog" as dialog
participant "WorkflowEditor" as editor
participant "RunPanel" as panel
participant "IPC" as ipc
participant "GraphEngine" as engine
participant "NodeFactory" as factory
participant "SQLite" as db

user -> editor : Click Run
editor -> editor : hasInputVariables?
alt has variables
  editor -> dialog : Show RunInputDialog
  user -> dialog : Fill variables
  dialog -> editor : onRun(inputs)
else no variables
  editor -> editor : handleRunWithInputs({})
end

editor -> editor : setShowRun(true)
editor -> editor : setIsRunning(true)
editor -> ipc : workflow.run(dsl, { inputs })

activate engine
engine -> engine : Topological sort nodes
engine -> db : createRun(workflowId, inputs)

loop for each node in sorted order
  engine -> engine : Check node.status (skip on error)
  engine -> factory : createNode(type, config)
  factory --> engine : NodeExecutor
  
  engine -> ipc : emit(node:start, nodeId)
  ipc -> editor : onEvent callback
  editor -> editor : updateNodeStatus(id, 'running')
  editor -> panel : Update node list
  
  alt LLM Node
    engine -> ipc : ai.chat(messages, provider)
    ipc -> ipc : Resolve provider from DB
    ipc -> ipc : Call OpenAI/Anthropic/Ollama
    ipc --> engine : response text
  else Code Node
    engine -> ipc : sandbox.execCode(code)
    ipc --> engine : stdout/stderr
  else Condition Node
    engine -> engine : Evaluate expression
    engine -> engine : Branch to true/false handle
  else Shell Node
    engine -> ipc : sandbox.exec(command)
    ipc --> engine : stdout/stderr
  else HTTP Node
    engine -> ipc : fetch(url, options)
    ipc --> engine : response
  else Agent Node
    engine -> engine : ReAct loop\nThought → Action → Observation
    engine -> ipc : ai.chat(messages)
    ipc --> engine : tool calls
    engine -> engine : Execute tools
    engine -> engine : Repeat until FINISH
  end
  
  alt success
    engine -> ipc : emit(node:complete, nodeId, output)
    ipc -> editor : onEvent callback
    editor -> editor : updateNodeStatus(id, 'completed', output)
    engine -> db : updateNodeRunStatus(id, 'completed', output)
  else error
    engine -> ipc : emit(node:error, nodeId, error)
    ipc -> editor : onEvent callback
    editor -> editor : updateNodeStatus(id, 'error', error)
    engine -> db : updateNodeRunStatus(id, 'error', error)
  end
end

engine -> db : updateRunStatus(id, 'complete')
engine -> ipc : emit(graph:complete)
ipc -> editor : onEvent callback
editor -> editor : setIsRunning(false)
editor -> panel : Show final status
deactivate engine

@enduml
