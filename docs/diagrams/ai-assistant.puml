@startuml ai-assistant
!theme plain
skin backgroundColor #0a0a0a
skin defaultFontColor #ededed
skin defaultFontSize 12
skinparam sequenceArrowColor #0070f3
skinparam sequenceLifeLineBorderColor #333333
skinparam sequenceParticipantBackgroundColor #171717
skinparam sequenceParticipantBorderColor #333333
skinparam sequenceParticipantFontColor #ededed
skinparam sequenceGroupBackgroundColor #111111
skinparam sequenceGroupBorderColor #333333

title **Evoflux — AI Assistant Sequence**\n

participant "User" as user
participant "AssistantPanel" as panel
participant "Engine" as engine
participant "Tools" as tools
participant "Provider" as provider
participant "Canvas" as canvas
participant "Store" as store

user -> panel : Type message
panel -> panel : addMessage(user)
panel -> panel : addMessage(assistant, streaming)
panel -> engine : runAssistant(options)

loop for i = 1..maxIterations (20)
  engine -> provider : ai.chat(messages, providerConfig)
  provider --> engine : LLM output
  
  engine -> engine : parseAgentOutput(output)
  
  alt type = "tool_call"
    engine -> panel : onThought(thought)
    panel -> panel : Update thought display
    
    engine -> tools : Execute tool(args)
    
    alt create_node
      tools -> store : addNode(type, label, config)
      store -> store : Append to nodes array
      store -> canvas : setNodes(updated)
      canvas -> canvas : React re-render
      tools --> engine : "Created node 'llm-abc'"
    else connect_nodes
      tools -> store : addEdge(source, target)
      store -> store : Append to edges array
      store -> canvas : setEdges(updated)
      tools --> engine : "Connected 'start-1' → 'llm-abc'"
    else get_workflow
      tools -> store : getNodes() + getEdges()
      store --> tools : Current canvas state
      tools --> engine : JSON workflow state
    else update_node
      tools -> store : updateNodeData(id, patch)
      store -> canvas : setNodes(updated)
      tools --> engine : "Updated node 'llm-abc'"
    else delete_node
      tools -> store : removeNode(id)
      store -> canvas : setNodes + setEdges
      tools --> engine : "Deleted node 'llm-abc'"
    else validate_workflow
      tools -> tools : Check edges, configs, triggers
      tools --> engine : Validation report
    else auto_layout
      tools -> store : autoLayout(nodes, edges)
      store -> canvas : setNodes(rearranged)
      tools --> engine : "Layout applied"
    end
    
    engine -> panel : onToolCall(name, args)
    panel -> panel : Show tool result bubble
    engine -> panel : onToolResult(name, result)
    
    engine -> engine : Append to messages[]
    engine -> engine : Continue loop
    
  else type = "finish"
    engine -> panel : onFinish(answer)
    panel -> panel : Update last message
    engine -> engine : Break loop
    
  else type = "error"
    engine -> panel : onError(message)
    panel -> panel : Show error
    engine -> engine : Break loop
  end
end

panel -> panel : setThinking(false)

@enduml
